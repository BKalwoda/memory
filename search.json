---
layout: null
permalink: /search.json
sitemap: false
---
[
{% for entry in site.knowledge %}
  {
    "title":    {{ entry.title | jsonify }},
    "url":      {{ entry.url | relative_url | jsonify }},
    "summary":  {{ entry.summary | default: "" | jsonify }},
    "category": {{ entry.category | default: "" | jsonify }},
    "tags":     {{ entry.tags | jsonify }},
    "date":     {{ entry.updated | default: entry.created | date: "%Y-%m-%d" | jsonify }},
    "body":     {{ entry.content | strip_html | normalize_whitespace | truncate: 2000 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
